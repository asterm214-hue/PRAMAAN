# PRAMAAN Backend Environment

# Database
DATABASE_URL=sqlite:///backend/pramaan.db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS (add frontend origins if needed)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=backend/uploads

